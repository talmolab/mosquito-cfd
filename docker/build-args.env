# IAMReX CFD Docker Build Arguments
# Pinned dependency commits for reproducible builds
# Last updated: 2026-02-25

# IAMReX - Immersed boundary AMReX (talmolab fork with arbitrary geometry)
# https://github.com/talmolab/IAMReX
# Branch: feature/arbitrary-geometry
IAMREX_REPO=https://github.com/talmolab/IAMReX.git
IAMREX_COMMIT=6d44f3552f3b29daa1028128126f213196b2d926

# AMReX - Adaptive mesh refinement framework (IAMReX's fork)
# https://github.com/ruohai0925/amrex (development branch)
# Note: This fork periodically rebases against upstream, so commits may change
AMREX_COMMIT=2e4b667c1bd9fb5cf42dff6a7a1af0dfc012a3d4

# AMReX-Hydro - Hydrodynamics routines for AMReX
# https://github.com/ruohai0925/AMReX-Hydro
AMREX_HYDRO_COMMIT=75da770ea36e4064b5947d7e56baa19f5bc92263

# CUDA configuration for A40 GPU (Ampere GA102)
CUDA_ARCH=86

# Minimum NVIDIA driver version for CUDA 12.4
# See: https://docs.nvidia.com/cuda/cuda-toolkit-release-notes/
MIN_DRIVER_VERSION=550.54.14