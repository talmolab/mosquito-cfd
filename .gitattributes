# Set default behavior to automatically normalize line endings
* text=auto

# Force LF line endings for all text files
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Jupyter notebooks
*.ipynb text eol=lf

# IAMReX input decks (extension-less) — pin LF so the committed sweep corpus is
# byte-reproducible on Windows and Linux (force-surrogate sweep generator).
examples/**/inputs.3d.* text eol=lf

# Documentation
*.rst text eol=lf
LICENSE text eol=lf
README text eol=lf

# Binary files (should not be modified)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.xlsx binary
*.xls binary
# Parquet datasets are binary — never normalize line endings or diff as text. The real
# force-surrogate dataset.parquet landed with the PR #16 Argo corpus (extracted by PR4).
*.parquet binary
# Torch model checkpoints are binary pickles — never EOL-normalize (force-surrogate PR5).
*.pt binary
*.pth binary
*.ckpt binary
*.csv text eol=lf

# T3b synthetic boxlib plotfile fixture (extension-less AMReX files). The Cell_D FAB is raw binary
# float64 — autocrlf / `* text=auto` would corrupt it and desync the Cell_H byte-offsets, so treat the
# whole fixture as binary (no EOL normalization; byte-identical across platforms for the regenerability
# test). yt still parses the LF-authored Header/Cell_H via universal newlines.
tests/fixtures/lev_boxlib_plt/** -text

# Windows specific files can use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf